# Django Settings - Production/Staging Environment Template

DEBUG=False

# Generate a new secret key for production (min 32 characters)
# Use: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-secret-key-here-min-32-chars-generate-new-one

# Database Configuration 
# PostgreSQL is used for ALL environments (local development, staging, and production)
# For local development on macOS:
#   DATABASE_URL=postgresql://postgres@localhost:5432/nasa_library_db
# For Railway production:
#   DATABASE_URL is set automatically by Railway when you connect PostgreSQL service
#   Format: postgresql://user:password@host:port/dbname
DATABASE_URL=postgresql://user:password@host:port/nasa_library_db

# Allowed Hosts (comma-separated, no spaces)
# For production: your-app-name.railway.app,www.your-app-name.railway.app
ALLOWED_HOSTS=localhost,127.0.0.1,your-railway-app-name.railway.app

# Python Environment
PYTHONUNBUFFERED=1
